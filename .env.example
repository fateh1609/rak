# --- RAK Oasis VPS deployment (.env for docker compose) ---

# PostgreSQL password (required)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT signing secret — 64+ random chars (required)
# Generate: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_RANDOM_CHARS

# Google Gemini API key for the AI advisor (optional — advisor degrades gracefully)
GEMINI_API_KEY=

# USDT/INR conversion rate used for payout calculations
USDT_INR_RATE=92

# Password for the seeded admin/agent/client demo accounts
SEED_PASSWORD=RakOasis@2026

# Public HTTP port nginx listens on
WEB_PORT=80
